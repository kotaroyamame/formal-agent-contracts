-- Online Auction System - VDM-SL Formal Specification (Run 3)
-- Explicit transition matrix with proof obligations

module AUCTION_TRANSITIONS

imports
  from VDM

types
  AuctionState = <Draft> | <Active> | <Ended> | <Paid> | <Shipped> | <Completed> | <Cancelled>;

  AuctionId = seq of char;
  UserId = seq of char;
  Money = nat;

  Bid ::
    bidder : UserId
    amount : Money
    ts : nat
  inv b == b.amount > 0;

  AuctionState_Trans ::
    from : AuctionState
    to : AuctionState
  inv trans ==
    -- Define valid state transitions explicitly
    (trans.from = <Draft> and (trans.to = <Active> or trans.to = <Cancelled>)) or
    (trans.from = <Active> and (trans.to = <Ended> or trans.to = <Cancelled>)) or
    (trans.from = <Ended> and (trans.to = <Paid> or trans.to = <Cancelled>)) or
    (trans.from = <Paid> and trans.to = <Shipped>) or
    (trans.from = <Shipped> and trans.to = <Completed>) or
    (trans.from = <Completed>) or
    (trans.from = <Cancelled>);

  Auction ::
    id : AuctionId
    seller : UserId
    starting_price : Money
    highest_bid : Money
    highest_bidder : [UserId]
    state : AuctionState
    bids : seq of Bid
    end_time : nat
    extensions : nat
    created : nat
  inv auction ==
    auction.starting_price > 0 and
    auction.extensions <= 10 and
    (auction.state = <Active> => auction.created < auction.end_time) and
    (auction.highest_bidder <> nil => auction.highest_bidder <> auction.seller) and
    (forall i in set inds auction.bids & auction.bids(i).bidder <> auction.seller) and
    (len auction.bids > 0 =>
      (auction.highest_bid >= auction.starting_price and
       forall i in set inds auction.bids & auction.bids(i).amount <= auction.highest_bid)) and
    (len auction.bids = 0 => auction.highest_bid = 0);

state Store of
  auctions : map AuctionId to Auction
init st == st`auctions = {|->}
end

operations
  -- Factory operation
  NewAuction(id : AuctionId, seller : UserId, price : Money, duration : nat, now : nat) result : AuctionId
  pre price > 0 and duration > 0 and id not in set dom auctions and now >= 0
  post let new_auction = mk_Auction(id, seller, price, 0, nil, <Draft>, [], now + duration, 0, now)
       in auctions = auctions~ union {id |-> new_auction}
  return id;

  -- Explicit state transition: Draft -> Active
  TransitionDraftToActive(id : AuctionId, now : nat) result : bool
  pre id in set dom auctions and
      auctions(id).state = <Draft> and
      now < auctions(id).end_time
  post auctions(id).state = <Active>;

  -- Explicit state transition: Active -> Ended (with proof of timing)
  TransitionActiveToEnded(id : AuctionId, now : nat) result : bool
  pre id in set dom auctions and
      auctions(id).state = <Active> and
      now >= auctions(id).end_time  -- PO: must prove now >= end_time
  post auctions(id).state = <Ended>;

  -- Explicit state transition: Ended -> Paid
  TransitionEndedToPaid(id : AuctionId, now : nat) result : bool
  pre id in set dom auctions and
      auctions(id).state = <Ended> and
      (now - auctions(id).end_time) <= 259200  -- PO: must prove elapsed <= 72 hours
  post auctions(id).state = <Paid>;

  -- Explicit state transition: Ended -> Cancelled (timeout)
  TransitionEndedToCancelled(id : AuctionId, now : nat) result : bool
  pre id in set dom auctions and
      auctions(id).state = <Ended> and
      (now - auctions(id).end_time) > 259200  -- PO: must prove elapsed > 72 hours
  post auctions(id).state = <Cancelled>;

  -- Explicit state transition: Paid -> Shipped
  TransitionPaidToShipped(id : AuctionId) result : bool
  pre id in set dom auctions and
      auctions(id).state = <Paid>
  post auctions(id).state = <Shipped>;

  -- Explicit state transition: Shipped -> Completed
  TransitionShippedToCompleted(id : AuctionId) result : bool
  pre id in set dom auctions and
      auctions(id).state = <Shipped>
  post auctions(id).state = <Completed>;

  -- Explicit state transition: Draft -> Cancelled
  TransitionDraftToCancelled(id : AuctionId) result : bool
  pre id in set dom auctions and
      auctions(id).state = <Draft>
  post auctions(id).state = <Cancelled>;

  -- Explicit state transition: Active -> Cancelled
  TransitionActiveToCancelled(id : AuctionId) result : bool
  pre id in set dom auctions and
      auctions(id).state = <Active>
  post auctions(id).state = <Cancelled>;

  -- Bidding with comprehensive constraints
  PlaceBidWithValidation(id : AuctionId, bidder : UserId, amount : Money, now : nat) result : bool
  pre id in set dom auctions and
      let auction = auctions(id)
      in auction.state = <Active> and
         bidder <> auction.seller and
         now >= auction.created and
         now < auction.end_time and
         amount > 0 and
         (len auction.bids = 0 => amount >= auction.starting_price) and
         (len auction.bids > 0 => amount > auction.highest_bid and
            amount >= auction.highest_bid + max_val(floor_val(auction.highest_bid / 100), 100))
  post let auction = auctions~(id),
           new_bid = mk_Bid(bidder, amount, now)
       in auctions(id).highest_bidder = bidder and
          auctions(id).highest_bid = amount and
          len auctions(id).bids = len auction.bids + 1 and
          (if (auction.end_time - now) <= 300 and auction.extensions < 10
           then (auctions(id).end_time = auction.end_time + 300 and
                 auctions(id).extensions = auction.extensions + 1)
           else (auctions(id).end_time = auction.end_time and
                 auctions(id).extensions = auction.extensions));

  -- Validation: Check if transition is valid
  IsValidTransition(id : AuctionId, target_state : AuctionState) result : bool
  pre id in set dom auctions
  post let current = auctions(id).state
       in if current = target_state
          then true
          else if current = <Draft> and (target_state = <Active> or target_state = <Cancelled>)
               then true
               else if current = <Active> and (target_state = <Ended> or target_state = <Cancelled>)
                    then true
                    else if current = <Ended> and (target_state = <Paid> or target_state = <Cancelled>)
                         then true
                         else if current = <Paid> and target_state = <Shipped>
                              then true
                              else if current = <Shipped> and target_state = <Completed>
                                   then true
                                   else false

end AUCTION_TRANSITIONS

functions
  floor_val : nat -> nat
  floor_val(n) == floor(n);

  max_val : nat * nat -> nat
  max_val(a, b) == if a >= b then a else b

end AUCTION_TRANSITIONS
