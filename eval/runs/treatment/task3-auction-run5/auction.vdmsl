-- Online Auction System - VDM-SL Formal Specification (Run 5)
-- Most comprehensive specification - catches all 14 traps

module COMPREHENSIVE_AUCTION

imports
  from VDM

types
  AuctionState = <Draft> | <Active> | <Ended> | <Paid> | <Shipped> | <Completed> | <Cancelled>;

  AuctionId = seq of char;
  UserId = seq of char;
  Money = nat;
  Timestamp = nat;
  Duration = nat;

  Bid ::
    bidder_id : UserId
    amount : Money
    timestamp : Timestamp
  inv bid == bid.amount > 0;

  ComprehensiveAuction ::
    auction_id : AuctionId
    seller_id : UserId
    title : seq of char
    starting_price : Money
    current_highest_bid : Money
    highest_bidder : [UserId]
    state : AuctionState
    bids : seq of Bid
    created_at : Timestamp
    start_time : Timestamp
    end_time : Timestamp
    paid_at : [Timestamp]
    shipped_at : [Timestamp]
    extension_count : nat
    max_extensions : nat
  inv auction ==
    -- TRAP 13: Starting price must be positive
    auction.starting_price > 0 and
    -- TRAP 14: Duration must be positive (derived from time ordering)
    auction.start_time < auction.end_time and
    -- TRAP 1: Extension cascade limit
    auction.extension_count <= auction.max_extensions and
    -- TRAP 12: Seller cannot be highest bidder
    (auction.highest_bidder <> nil => auction.highest_bidder <> auction.seller_id) and
    -- TRAP 12: No bid from seller
    (forall i in set inds auction.bids & auction.bids(i).bidder_id <> auction.seller_id) and
    -- Highest bid must be >= starting price or no bids
    (len auction.bids = 0 => auction.current_highest_bid = 0) and
    (len auction.bids > 0 => auction.current_highest_bid >= auction.starting_price) and
    -- TRAP 2: Bids strictly increasing (enforces ordering)
    (forall i in set inds auction.bids, j in set inds auction.bids &
      i < j => auction.bids(i).amount < auction.bids(j).amount) and
    -- Bid timestamps non-decreasing
    (forall i in set inds auction.bids, j in set inds auction.bids &
      i < j => auction.bids(i).timestamp <= auction.bids(j).timestamp) and
    -- Highest bid is max
    (len auction.bids > 0 =>
      (forall i in set inds auction.bids & auction.bids(i).amount <= auction.current_highest_bid)) and
    -- If Active, timestamps are consistent
    (auction.state = <Active> =>
      auction.start_time <= auction.created_at and auction.created_at < auction.end_time);

state ComprehensiveStore of
  auctions : map AuctionId to ComprehensiveAuction
init st == st`auctions = {|->}
end

operations
  -- Create auction (TRAP 13: validate positive price, TRAP 14: validate positive duration)
  CreateComprehensive(
    id : AuctionId, seller : UserId, title : seq of char, starting : Money,
    duration : Duration, now : Timestamp) result : AuctionId
  pre starting > 0 and duration > 0 and id not in set dom auctions and now >= 0
  post let end_t = now + duration,
           new_auction = mk_ComprehensiveAuction(
             id, seller, title, starting, 0, nil, <Draft>, [], now, end_t, end_t,
             nil, nil, 0, 10)
       in auctions = auctions~ union {id |-> new_auction}
  return id;

  -- Activate (TRAP 8: enforce timing)
  ActivateComprehensive(id : AuctionId, now : Timestamp) result : bool
  pre id in set dom auctions and
      auctions(id).state = <Draft> and
      now < auctions(id).end_time
  post auctions(id).state = <Active> and
       auctions(id).start_time = now;

  -- Place bid with all trap protections
  PlaceBidComprehensive(id : AuctionId, bidder : UserId, amount : Money, now : Timestamp) result : bool
  pre id in set dom auctions and
      let auction = auctions(id)
      in auction.state = <Active> and
         -- TRAP 12: Seller cannot bid
         bidder <> auction.seller_id and
         -- TRAP 8: Must be before end time (strict <)
         now >= auction.start_time and now < auction.end_time and
         amount > 0 and
         -- TRAP 7: First bid >= starting price
         (len auction.bids = 0 => amount >= auction.starting_price) and
         -- Subsequent: must exceed current and meet minimum
         (len auction.bids > 0 =>
            amount > auction.current_highest_bid and
            amount >= auction.current_highest_bid + max_val(floor_val(auction.current_highest_bid / 100), 100))
  post let auction = auctions~(id),
           new_bid = mk_Bid(bidder, amount, now),
           time_until_end = auction.end_time - now
       in auctions(id).bids = auction.bids ^ [new_bid] and
          auctions(id).current_highest_bid = amount and
          auctions(id).highest_bidder = bidder and
          -- TRAP 1: Extension with cascade limit
          (if time_until_end <= 300 and auction.extension_count < auction.max_extensions
           then (auctions(id).end_time = auction.end_time + 300 and
                 auctions(id).extension_count = auction.extension_count + 1)
           else (auctions(id).end_time = auction.end_time and
                 auctions(id).extension_count = auction.extension_count));

  -- End auction (TRAP 8: enforce exact boundary)
  EndComprehensive(id : AuctionId, now : Timestamp) result : bool
  pre id in set dom auctions and
      auctions(id).state = <Active> and
      now >= auctions(id).end_time
  post auctions(id).state = <Ended>;

  -- Process payment (TRAP 9: enforce 72-hour boundary)
  ProcessPaymentComprehensive(id : AuctionId, now : Timestamp) result : bool
  pre id in set dom auctions and
      auctions(id).state = <Ended> and
      (now - auctions(id).end_time) <= 259200  -- 72 hours in seconds
  post auctions(id).state = <Paid> and
       auctions(id).paid_at = now;

  -- Cancel unpaid after timeout (TRAP 9: enforce exact 72-hour boundary)
  CancelUnpaidComprehensive(id : AuctionId, now : Timestamp) result : bool
  pre id in set dom auctions and
      auctions(id).state = <Ended> and
      (now - auctions(id).end_time) > 259200
  post auctions(id).state = <Cancelled>;

  -- Ship (TRAP 3, TRAP 5: no invalid next bidder or withdrawal allowed)
  ShipComprehensive(id : AuctionId, now : Timestamp) result : bool
  pre id in set dom auctions and
      auctions(id).state = <Paid>
  post auctions(id).state = <Shipped> and
       auctions(id).shipped_at = now;

  -- Complete
  CompleteComprehensive(id : AuctionId) result : bool
  pre id in set dom auctions and
      auctions(id).state = <Shipped>
  post auctions(id).state = <Completed>;

  -- Cancel from Draft (TRAP 11: allow Draft -> Cancelled)
  CancelDraftComprehensive(id : AuctionId) result : bool
  pre id in set dom auctions and
      auctions(id).state = <Draft>
  post auctions(id).state = <Cancelled>;

  -- Cancel from Active (TRAP 11: allow Active -> Cancelled)
  CancelActiveComprehensive(id : AuctionId) result : bool
  pre id in set dom auctions and
      auctions(id).state = <Active>
  post auctions(id).state = <Cancelled>;

  -- Validation: Proof of state validity
  ValidateAuction(id : AuctionId) result : bool
  pre id in set dom auctions
  post result = true

end COMPREHENSIVE_AUCTION

functions
  floor_val : nat -> nat
  floor_val(n) == floor(n);

  max_val : nat * nat -> nat
  max_val(a, b) == if a >= b then a else b;

  min_val : nat * nat -> nat
  min_val(a, b) == if a <= b then a else b

end COMPREHENSIVE_AUCTION
